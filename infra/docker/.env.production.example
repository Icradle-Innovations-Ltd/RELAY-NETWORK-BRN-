# ─── BRN Production Environment ───
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.

# Your domain pointed at this VPS (A record)
BRN_DOMAIN=relay.example.com

# Postgres
POSTGRES_USER=brn
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# Secrets — generate each with:  openssl rand -hex 32
BRN_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
BRN_SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
BRN_RELAY_USAGE_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
