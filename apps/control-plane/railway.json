{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "dockerfilePath": "../../infra/docker/control-plane.Dockerfile",
    "watchPatterns": [
      "apps/control-plane/**",
      "packages/contracts/**"
    ]
  },
  "deploy": {
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
